<!DOCTYPE html>
<html lang="kk">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Әміржол — 20 жас 🎂</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Montserrat:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #d4af5e;
    --gold2: #f0d080;
    --cream: #faf6ee;
    --dark: #0d0a05;
    --dark2: #1a1408;
    --text: #e8dfc8;
    --muted: #a09070;
  }
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--dark);
    color: var(--text);
    font-family: 'Cormorant Garamond', serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── CANVAS BACKGROUND ── */
  #bg-canvas {
    position: fixed; inset: 0; z-index: 0; pointer-events: none;
  }

  /* ── INTRO SCREEN ── */
  #intro {
    position: fixed; inset: 0; z-index: 100;
    background: var(--dark);
    display: flex; align-items: center; justify-content: center;
    flex-direction: column; gap: 32px;
    transition: opacity 1.2s ease, visibility 1.2s;
  }
  #intro.hidden { opacity: 0; visibility: hidden; }

  .intro-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 7vw, 72px);
    font-style: italic;
    color: var(--gold);
    text-align: center;
    line-height: 1.2;
    letter-spacing: 2px;
    text-shadow: 0 0 60px rgba(212,175,94,0.4);
    animation: fadeUp 1.2s ease forwards;
    opacity: 0;
  }
  .intro-sub {
    font-size: clamp(14px, 3vw, 20px);
    color: var(--muted);
    text-align: center;
    letter-spacing: 4px;
    text-transform: uppercase;
    animation: fadeUp 1.2s 0.3s ease forwards;
    opacity: 0;
  }

  #start-btn {
    margin-top: 20px;
    padding: 18px 52px;
    background: transparent;
    border: 1px solid var(--gold);
    color: var(--gold);
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 5px;
    text-transform: uppercase;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: color 0.4s;
    animation: fadeUp 1.2s 0.6s ease forwards;
    opacity: 0;
  }
  #start-btn::before {
    content: '';
    position: absolute; inset: 0;
    background: var(--gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
    z-index: -1;
  }
  #start-btn:hover { color: var(--dark); }
  #start-btn:hover::before { transform: scaleX(1); }

  /* ── MAIN CONTENT ── */
  #main {
    position: relative; z-index: 1;
    opacity: 0; transition: opacity 1.5s ease;
  }
  #main.visible { opacity: 1; }

  /* ── HERO SECTION ── */
  .hero {
    min-height: 100vh;
    display: flex; align-items: center; justify-content: center;
    flex-direction: column;
    text-align: center;
    padding: 60px 24px;
    position: relative;
  }

  .hero-eyebrow {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 8px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 28px;
    opacity: 0;
    animation: none;
  }
  .hero-name {
    font-family: 'Playfair Display', serif;
    font-size: clamp(56px, 14vw, 160px);
    font-weight: 900;
    line-height: 0.9;
    color: transparent;
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold2) 45%, var(--gold) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    letter-spacing: -2px;
    position: relative;
    opacity: 0;
  }
  .hero-age {
    font-family: 'Playfair Display', serif;
    font-size: clamp(18px, 5vw, 48px);
    font-style: italic;
    color: var(--muted);
    margin-top: 16px;
    letter-spacing: 3px;
    opacity: 0;
  }
  .hero-divider {
    width: 1px;
    height: 80px;
    background: linear-gradient(to bottom, transparent, var(--gold), transparent);
    margin: 40px auto;
    opacity: 0;
  }
  .hero-wish {
    font-size: clamp(16px, 3vw, 24px);
    font-style: italic;
    color: var(--text);
    max-width: 600px;
    line-height: 1.8;
    opacity: 0;
  }

  /* ── VIDEO SECTION ── */
  .video-section {
    padding: 80px 24px;
    position: relative;
  }
  .section-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 8px;
    text-transform: uppercase;
    color: var(--gold);
    text-align: center;
    margin-bottom: 48px;
    opacity: 0.7;
  }
  .video-frame {
    max-width: 480px;
    margin: 0 auto;
    position: relative;
  }
  .video-frame::before {
    content: '';
    position: absolute;
    inset: -2px;
    background: linear-gradient(135deg, var(--gold), transparent 40%, var(--gold) 100%);
    border-radius: 4px;
    z-index: -1;
  }
  .video-frame video {
    width: 100%;
    display: block;
    border-radius: 3px;
    background: #000;
  }
  .video-caption {
    text-align: center;
    margin-top: 20px;
    font-style: italic;
    color: var(--muted);
    font-size: 15px;
    letter-spacing: 1px;
  }

  /* ── MUSIC SECTION ── */
  .music-section {
    padding: 80px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
  }
  .music-card {
    background: rgba(212,175,94,0.05);
    border: 1px solid rgba(212,175,94,0.2);
    border-radius: 4px;
    padding: 40px 48px;
    max-width: 500px;
    width: 100%;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .music-card::after {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(212,175,94,0.06), transparent);
    animation: shimmer 3s infinite;
  }
  @keyframes shimmer { to { left: 200%; } }
  
  .music-icon {
    font-size: 48px;
    margin-bottom: 16px;
    display: block;
  }
  .music-title {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    color: var(--gold);
    margin-bottom: 8px;
  }
  .music-sub {
    font-size: 14px;
    color: var(--muted);
    letter-spacing: 2px;
    margin-bottom: 28px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 300;
    text-transform: uppercase;
  }

  .play-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 14px 36px;
    background: transparent;
    border: 1px solid var(--gold);
    color: var(--gold);
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 4px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s;
    position: relative;
    z-index: 1;
  }
  .play-btn:hover {
    background: var(--gold);
    color: var(--dark);
    box-shadow: 0 0 40px rgba(212,175,94,0.3);
  }
  .play-btn.playing {
    background: rgba(212,175,94,0.15);
    border-color: var(--gold2);
    color: var(--gold2);
  }
  .play-icon { font-size: 18px; transition: transform 0.2s; }

  /* Audio visualizer bars */
  .visualizer {
    display: flex;
    align-items: flex-end;
    gap: 3px;
    height: 32px;
    margin-top: 20px;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.4s;
  }
  .visualizer.active { opacity: 1; }
  .v-bar {
    width: 3px;
    background: var(--gold);
    border-radius: 2px;
    animation: none;
    height: 4px;
  }
  .visualizer.active .v-bar { animation: vbar 0.8s ease-in-out infinite alternate; }
  .v-bar:nth-child(1)  { animation-delay: 0s;    }
  .v-bar:nth-child(2)  { animation-delay: 0.1s;  }
  .v-bar:nth-child(3)  { animation-delay: 0.2s;  }
  .v-bar:nth-child(4)  { animation-delay: 0.05s; }
  .v-bar:nth-child(5)  { animation-delay: 0.15s; }
  .v-bar:nth-child(6)  { animation-delay: 0.25s; }
  .v-bar:nth-child(7)  { animation-delay: 0.08s; }
  .v-bar:nth-child(8)  { animation-delay: 0.18s; }
  .v-bar:nth-child(9)  { animation-delay: 0.03s; }
  .v-bar:nth-child(10) { animation-delay: 0.13s; }
  @keyframes vbar {
    from { height: 3px; }
    to   { height: 28px; }
  }

  /* ── BIRTHDAY CAKE SECTION ── */
  .cake-section {
    padding: 80px 24px 120px;
    text-align: center;
    position: relative;
  }
  .cake-number {
    font-family: 'Playfair Display', serif;
    font-size: clamp(120px, 25vw, 240px);
    font-weight: 900;
    color: transparent;
    -webkit-text-stroke: 1px rgba(212,175,94,0.3);
    line-height: 1;
    position: relative;
    user-select: none;
  }
  .cake-number span {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    font-size: clamp(40px, 8vw, 80px);
    -webkit-text-stroke: 0;
    color: var(--gold);
    text-shadow: 0 0 40px rgba(212,175,94,0.5);
    font-style: italic;
    white-space: nowrap;
  }

  /* ── MESSAGE ── */
  .message-section {
    max-width: 640px;
    margin: 0 auto;
    padding: 60px 24px 100px;
    text-align: center;
  }
  .message-text {
    font-size: clamp(17px, 3vw, 22px);
    line-height: 2;
    color: var(--text);
    font-style: italic;
    position: relative;
  }
  .message-text::before {
    content: '"';
    font-size: 120px;
    color: rgba(212,175,94,0.1);
    font-family: 'Playfair Display', serif;
    position: absolute;
    top: -40px; left: -20px;
    line-height: 1;
  }
  .message-sig {
    margin-top: 40px;
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    letter-spacing: 6px;
    text-transform: uppercase;
    color: var(--gold);
  }

  /* ── CONFETTI CANVAS ── */
  #confetti-canvas {
    position: fixed; inset: 0; z-index: 200;
    pointer-events: none;
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  .reveal { opacity: 0; transform: translateY(40px); transition: opacity 0.9s ease, transform 0.9s ease; }
  .reveal.in { opacity: 1; transform: none; }

  /* ── DECORATIVE LINES ── */
  .deco-line {
    display: flex; align-items: center; gap: 20px;
    max-width: 400px; margin: 0 auto 60px;
  }
  .deco-line::before, .deco-line::after {
    content: ''; flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(212,175,94,0.4), transparent);
  }
  .deco-line span {
    color: var(--gold); font-size: 14px; letter-spacing: 2px;
    white-space: nowrap;
  }

  /* scrollbar */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--dark); }
  ::-webkit-scrollbar-thumb { background: rgba(212,175,94,0.3); border-radius: 2px; }
</style>
</head>
<body>

<canvas id="bg-canvas"></canvas>
<canvas id="confetti-canvas"></canvas>

<!-- INTRO SCREEN -->
<div id="intro">
  <div class="intro-title">Туған күніңмен<br>Әміржол</div>
  <div class="intro-sub">20 жас · 2006 — 2026</div>
  <button id="start-btn" onclick="beginCelebration()">Ашу</button>
</div>

<!-- MAIN CONTENT -->
<div id="main">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-eyebrow reveal">— Жиырма жасқа толған күн —</div>
    <div class="hero-name reveal">Әміржол</div>
    <div class="hero-age reveal">XX жас</div>
    <div class="hero-divider reveal"></div>
    <div class="hero-wish reveal">
      Өмірдегі ең маңызды жиырма жылды аяқтадың.<br>
      Алдыңда — шексіз мүмкіндіктер.
    </div>
  </section>

  <!-- VIDEO 1 -->
  <section class="video-section">
    <div class="section-label">— Сәт —</div>
    <div class="video-frame reveal">
      <video id="vid1" playsinline controls>
        <source src="data:video/mp4;base64," type="video/mp4">
      </video>
    </div>
    <div class="video-caption reveal">Туған күн сәтінің естелігі</div>
  </section>

  <!-- VIDEO 2 -->
  <section class="video-section" style="padding-top:0;">
    <div class="video-frame reveal">
      <video id="vid2" playsinline controls>
        <source src="data:video/mp4;base64," type="video/mp4">
      </video>
    </div>
    <div class="video-caption reveal">Достармен бірге</div>
  </section>

  <!-- MUSIC -->
  <section class="music-section">
    <div class="deco-line reveal"><span>♩ Туған күн әні</span></div>
    <div class="music-card reveal">
      <span class="music-icon">🎵</span>
      <div class="music-title">Happy Birthday</div>
      <div class="music-sub">Әміржол үшін · 20 жас</div>
      <button class="play-btn" id="music-btn" onclick="toggleMusic()">
        <span class="play-icon" id="play-icon">▶</span>
        <span id="play-label">Тыңда</span>
      </button>
      <div class="visualizer" id="visualizer">
        <div class="v-bar"></div><div class="v-bar"></div><div class="v-bar"></div>
        <div class="v-bar"></div><div class="v-bar"></div><div class="v-bar"></div>
        <div class="v-bar"></div><div class="v-bar"></div><div class="v-bar"></div>
        <div class="v-bar"></div>
      </div>
    </div>
    <audio id="birthday-audio" loop>
      <source src="data:audio/mpeg;base64," type="audio/mpeg">
    </audio>
  </section>

  <!-- 20 -->
  <section class="cake-section">
    <div class="cake-number reveal">20<span>Жас құтты болсын!</span></div>
  </section>

  <!-- MESSAGE -->
  <section class="message-section">
    <div class="deco-line reveal"><span>✦</span></div>
    <div class="message-text reveal">
      Жиырма жыл — бұл тек басталуы ғана.<br>
      Алдыңда ең үлкен жеңістерің, ең жарқын сәттерің.<br>
      Өзіңе сен, ал дүние сенің алдыңда ашылар.
    </div>
    <div class="message-sig reveal">— Қайнар · kainar.space —</div>
  </section>

</div><!-- /main -->

<script>
// ── BACKGROUND CANVAS (golden particles) ──
(function(){
  const canvas = document.getElementById('bg-canvas');
  const ctx = canvas.getContext('2d');
  let W, H, particles = [];
  function resize(){ W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }
  function mkParticle(){
    return {
      x: Math.random()*W, y: Math.random()*H,
      r: Math.random()*1.2+0.3,
      vx: (Math.random()-0.5)*0.3,
      vy: -(Math.random()*0.4+0.1),
      a: Math.random()*0.5+0.1,
      life: Math.random()
    };
  }
  function init(){ resize(); particles=[]; for(let i=0;i<120;i++) particles.push(mkParticle()); }
  function draw(){
    ctx.clearRect(0,0,W,H);
    // subtle dark gradient
    const g = ctx.createRadialGradient(W/2,H/2,0,W/2,H/2,Math.max(W,H)*0.7);
    g.addColorStop(0,'rgba(26,20,8,0)');
    g.addColorStop(1,'rgba(0,0,0,0.4)');
    ctx.fillStyle = g; ctx.fillRect(0,0,W,H);
    particles.forEach(p=>{
      p.x += p.vx; p.y += p.vy; p.life += 0.003;
      if(p.y < -5 || p.life > 1){ Object.assign(p, mkParticle()); p.y = H; }
      const pulse = 0.4+0.6*Math.abs(Math.sin(p.life*Math.PI));
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI*2);
      ctx.fillStyle = `rgba(212,175,94,${p.a*pulse})`;
      ctx.fill();
    });
    requestAnimationFrame(draw);
  }
  window.addEventListener('resize', init);
  init(); draw();
})();

// ── CONFETTI ──
const confCanvas = document.getElementById('confetti-canvas');
const confCtx = confCanvas.getContext('2d');
let confetti = [], confRunning = false;
function resizeConf(){ confCanvas.width=window.innerWidth; confCanvas.height=window.innerHeight; }
window.addEventListener('resize', resizeConf); resizeConf();
function launchConfetti(){
  confRunning = true;
  const colors = ['#d4af5e','#f0d080','#fff','#ffd700','#c0a030','#fffacd'];
  for(let i=0;i<180;i++){
    confetti.push({
      x: Math.random()*confCanvas.width,
      y: -10 - Math.random()*confCanvas.height*0.5,
      w: 6+Math.random()*8, h: 3+Math.random()*5,
      color: colors[Math.floor(Math.random()*colors.length)],
      rot: Math.random()*Math.PI*2,
      vx: (Math.random()-0.5)*4,
      vy: 1.5+Math.random()*3,
      vr: (Math.random()-0.5)*0.15,
      life: 1
    });
  }
  animateConf();
}
function animateConf(){
  confCtx.clearRect(0,0,confCanvas.width,confCanvas.height);
  confetti = confetti.filter(c=>{
    c.x+=c.vx; c.y+=c.vy; c.rot+=c.vr; c.vx*=0.99;
    if(c.y > confCanvas.height+20) return false;
    confCtx.save();
    confCtx.translate(c.x,c.y); confCtx.rotate(c.rot);
    confCtx.globalAlpha = Math.min(1, c.y/(confCanvas.height*0.7));
    confCtx.fillStyle = c.color;
    confCtx.fillRect(-c.w/2,-c.h/2,c.w,c.h);
    confCtx.restore();
    return true;
  });
  if(confetti.length>0) requestAnimationFrame(animateConf);
  else confRunning = false;
}

// ── BEGIN CELEBRATION ──
function beginCelebration(){
  const intro = document.getElementById('intro');
  intro.classList.add('hidden');
  setTimeout(()=>{
    const main = document.getElementById('main');
    main.classList.add('visible');
    launchConfetti();
    // Trigger reveal animations
    setTimeout(initReveal, 300);
    setTimeout(launchConfetti, 2000);
  }, 800);
}

// ── SCROLL REVEAL ──
function initReveal(){
  const els = document.querySelectorAll('.reveal');
  const obs = new IntersectionObserver(entries=>{
    entries.forEach(e=>{ if(e.isIntersecting) e.target.classList.add('in'); });
  },{threshold:0.12});
  els.forEach(el=>obs.observe(el));
  // Also immediately reveal visible ones
  els.forEach(el=>{
    const r = el.getBoundingClientRect();
    if(r.top < window.innerHeight) el.classList.add('in');
  });
}

// ── MUSIC TOGGLE ──
let musicPlaying = false;
function toggleMusic(){
  const audio = document.getElementById('birthday-audio');
  const btn = document.getElementById('music-btn');
  const icon = document.getElementById('play-icon');
  const label = document.getElementById('play-label');
  const viz = document.getElementById('visualizer');
  if(!musicPlaying){
    audio.play().then(()=>{
      musicPlaying = true;
      btn.classList.add('playing');
      icon.textContent = '■';
      label.textContent = 'Тоқтату';
      viz.classList.add('active');
      launchConfetti();
    }).catch(()=>{});
  } else {
    audio.pause();
    musicPlaying = false;
    btn.classList.remove('playing');
    icon.textContent = '▶';
    label.textContent = 'Тыңда';
    viz.classList.remove('active');
  }
}
</script>
</body>
</html>
