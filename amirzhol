<!DOCTYPE html>
<html lang="kk">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Әміржол — 20 жас 🎂</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=DM+Sans:wght@300;400;600&family=Noto+Serif+KZ:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }
html, body { width:100%; height:100%; overflow:hidden; background:#000; }

canvas#fw { position:fixed; inset:0; z-index:0; }

/* overlay content */
#overlay {
  position:fixed; inset:0; z-index:10;
  display:flex; flex-direction:column;
  align-items:center; justify-content:center;
  pointer-events:none;
  gap:0;
}

.top-label {
  font-family:'DM Sans', sans-serif;
  font-size:clamp(11px,2vw,16px);
  letter-spacing:10px;
  text-transform:uppercase;
  color:rgba(255,255,255,0.5);
  margin-bottom:28px;
  opacity:0;
  animation: fadeUp 1.2s 0.5s ease forwards;
}

.big-name {
  font-family:'Orbitron', sans-serif;
  font-size:clamp(52px,14vw,160px);
  font-weight:900;
  letter-spacing:-2px;
  line-height:1;
  color:#fff;
  text-align:center;
  opacity:0;
  animation: fadeUp 1.2s 0.8s ease forwards;
  text-shadow:
    0 0 40px rgba(255,255,255,0.6),
    0 0 80px rgba(255,100,200,0.3),
    0 0 120px rgba(100,180,255,0.2);
}

.age-line {
  font-family:'DM Sans', sans-serif;
  font-size:clamp(16px,4vw,48px);
  font-weight:300;
  color:rgba(255,255,255,0.7);
  letter-spacing:8px;
  margin-top:16px;
  opacity:0;
  animation: fadeUp 1.2s 1.1s ease forwards;
}

.divider {
  width:60px; height:1px;
  background:rgba(255,255,255,0.25);
  margin:36px auto;
  opacity:0;
  animation: fadeIn 1s 1.4s ease forwards;
}

.wish {
  font-family:'DM Sans', sans-serif;
  font-size:clamp(15px,2.5vw,22px);
  font-weight:300;
  color:rgba(255,255,255,0.65);
  text-align:center;
  letter-spacing:1px;
  line-height:1.9;
  max-width:520px;
  padding:0 24px;
  opacity:0;
  animation: fadeUp 1.2s 1.7s ease forwards;
}

.bottom-sig {
  position:fixed;
  bottom:32px;
  left:50%;
  transform:translateX(-50%);
  font-family:'DM Sans',sans-serif;
  font-size:11px;
  letter-spacing:5px;
  text-transform:uppercase;
  color:rgba(255,255,255,0.25);
  opacity:0;
  animation: fadeIn 1s 2.5s ease forwards;
  z-index:10;
  pointer-events:none;
  white-space:nowrap;
}

@keyframes fadeUp {
  from { opacity:0; transform:translateY(28px); }
  to   { opacity:1; transform:translateY(0); }
}
@keyframes fadeIn {
  from { opacity:0; }
  to   { opacity:1; }
}
</style>
</head>
<body>

<canvas id="fw"></canvas>

<div id="overlay">
  <div class="top-label">— 2006 · 2026 —</div>
  <div class="big-name">Әміржол</div>
  <div class="age-line">20 жас</div>
  <div class="divider"></div>
  <div class="wish">
    Туған күніңмен! 🎂<br>
    Арман-мақсаттарың орындалсын,<br>
    өмірің мол болсын.
  </div>
</div>

<div class="bottom-sig">kainar.space · 2026</div>

<script>
const canvas = document.getElementById('fw');
const ctx = canvas.getContext('2d');

let W, H;
function resize() {
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight;
}
window.addEventListener('resize', resize);
resize();

// ── PARTICLE CLASS ──
class Particle {
  constructor(x, y, color, vx, vy, gravity, decay, size) {
    this.x = x; this.y = y;
    this.color = color;
    this.vx = vx; this.vy = vy;
    this.gravity = gravity ?? 0.06;
    this.decay = decay ?? (0.012 + Math.random() * 0.008);
    this.size = size ?? (1.5 + Math.random() * 2);
    this.alpha = 1;
    this.trail = [];
  }
  update() {
    this.trail.push({x: this.x, y: this.y, a: this.alpha});
    if (this.trail.length > 6) this.trail.shift();
    this.vx *= 0.98;
    this.vy += this.gravity;
    this.vy *= 0.98;
    this.x += this.vx;
    this.y += this.vy;
    this.alpha -= this.decay;
    this.size *= 0.995;
  }
  draw() {
    // trail
    for (let i = 0; i < this.trail.length; i++) {
      const t = this.trail[i];
      const ta = (i / this.trail.length) * t.a * 0.4;
      ctx.beginPath();
      ctx.arc(t.x, t.y, this.size * (i / this.trail.length) * 0.6, 0, Math.PI * 2);
      ctx.fillStyle = this.color.replace('1)', ta + ')');
      ctx.fill();
    }
    ctx.beginPath();
    ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
    ctx.fillStyle = this.color.replace('1)', this.alpha + ')');
    ctx.fill();
  }
  get dead() { return this.alpha <= 0; }
}

// ── ROCKET CLASS ──
class Rocket {
  constructor(x, targetY, color) {
    this.x = x;
    this.y = H + 20;
    this.targetY = targetY;
    this.vy = -((H - targetY) / 55);
    this.vx = (Math.random() - 0.5) * 1.5;
    this.color = color;
    this.trail = [];
    this.exploded = false;
  }
  update() {
    this.trail.push({x: this.x, y: this.y});
    if (this.trail.length > 18) this.trail.shift();
    this.x += this.vx;
    this.y += this.vy;
    this.vy += 0.03;
    if (this.y <= this.targetY) this.explode();
  }
  draw() {
    for (let i = 0; i < this.trail.length; i++) {
      const t = this.trail[i];
      const a = (i / this.trail.length) * 0.6;
      ctx.beginPath();
      ctx.arc(t.x, t.y, 2 * (i / this.trail.length), 0, Math.PI * 2);
      ctx.fillStyle = `rgba(255,220,100,${a})`;
      ctx.fill();
    }
    ctx.beginPath();
    ctx.arc(this.x, this.y, 3, 0, Math.PI * 2);
    ctx.fillStyle = '#fff';
    ctx.fill();
  }
  explode() {
    if (this.exploded) return;
    this.exploded = true;
    const count = 120 + Math.floor(Math.random() * 80);
    const type = Math.floor(Math.random() * 6);
    for (let i = 0; i < count; i++) {
      let vx, vy, size, decay, gravity, col;
      const angle = (Math.PI * 2 / count) * i + Math.random() * 0.15;
      col = this.color;

      if (type === 0) {
        // classic burst
        const speed = 2 + Math.random() * 5;
        vx = Math.cos(angle) * speed;
        vy = Math.sin(angle) * speed;
        size = 2 + Math.random() * 2.5;
        decay = 0.013 + Math.random() * 0.007;
        gravity = 0.07;
      } else if (type === 1) {
        // ring
        const speed = 4 + Math.random() * 1.5;
        vx = Math.cos(angle) * speed;
        vy = Math.sin(angle) * speed * 0.4;
        size = 1.5 + Math.random() * 1.5;
        decay = 0.014;
        gravity = 0.05;
      } else if (type === 2) {
        // star / sparse
        if (i % 3 !== 0) continue;
        const speed = 3 + Math.random() * 6;
        vx = Math.cos(angle) * speed;
        vy = Math.sin(angle) * speed;
        size = 2.5 + Math.random() * 3;
        decay = 0.009;
        gravity = 0.06;
      } else if (type === 3) {
        // willow (drooping)
        const speed = 2 + Math.random() * 4;
        vx = Math.cos(angle) * speed;
        vy = Math.sin(angle) * speed;
        size = 1.5 + Math.random() * 2;
        decay = 0.008;
        gravity = 0.12;
      } else if (type === 4) {
        // crossette (secondary pops)
        const speed = 3 + Math.random() * 4;
        vx = Math.cos(angle) * speed;
        vy = Math.sin(angle) * speed;
        size = 2 + Math.random() * 2;
        decay = 0.015;
        gravity = 0.06;
        // add secondary particles
        if (i % 8 === 0) {
          setTimeout(() => {
            for (let j = 0; j < 8; j++) {
              const a2 = Math.random() * Math.PI * 2;
              const sp2 = 1 + Math.random() * 3;
              particles.push(new Particle(
                this.x + vx * 20, this.y + vy * 20,
                col, Math.cos(a2)*sp2, Math.sin(a2)*sp2,
                0.08, 0.02, 1.5
              ));
            }
          }, 300 + Math.random() * 200);
        }
      } else {
        // chrysanthemum
        const speed = 1.5 + Math.random() * 5;
        vx = Math.cos(angle) * speed;
        vy = Math.sin(angle) * speed;
        size = 1.8 + Math.random() * 2;
        decay = 0.011;
        gravity = 0.055;
      }

      particles.push(new Particle(this.x, this.y, col, vx, vy, gravity, decay, size));
    }

    // center flash
    for (let i = 0; i < 20; i++) {
      const a = Math.random() * Math.PI * 2;
      const sp = Math.random() * 2;
      particles.push(new Particle(this.x, this.y, 'rgba(255,255,255,1)', Math.cos(a)*sp, Math.sin(a)*sp, 0.02, 0.04, 3 + Math.random()*3));
    }
  }
  get done() { return this.exploded; }
}

// ── PALETTE ──
const palettes = [
  ['rgba(255,80,80,1)', 'rgba(255,150,80,1)', 'rgba(255,220,80,1)'],
  ['rgba(80,180,255,1)', 'rgba(120,80,255,1)', 'rgba(200,80,255,1)'],
  ['rgba(80,255,160,1)', 'rgba(80,220,255,1)', 'rgba(255,255,255,1)'],
  ['rgba(255,120,200,1)', 'rgba(255,80,120,1)', 'rgba(255,200,80,1)'],
  ['rgba(255,200,80,1)', 'rgba(255,255,255,1)', 'rgba(255,160,80,1)'],
  ['rgba(140,80,255,1)', 'rgba(80,140,255,1)', 'rgba(80,220,200,1)'],
];

let particles = [];
let rockets = [];

function randomColor() {
  const p = palettes[Math.floor(Math.random() * palettes.length)];
  return p[Math.floor(Math.random() * p.length)];
}

function launchRocket() {
  const x = W * 0.15 + Math.random() * W * 0.7;
  const targetY = H * 0.08 + Math.random() * H * 0.42;
  rockets.push(new Rocket(x, targetY, randomColor()));
}

// ── LAUNCH SCHEDULE ──
// burst at start
setTimeout(launchRocket, 200);
setTimeout(launchRocket, 400);
setTimeout(launchRocket, 700);
setTimeout(launchRocket, 1000);
setTimeout(launchRocket, 1400);
setTimeout(launchRocket, 1800);

// then ongoing
function scheduleNext() {
  const delay = 600 + Math.random() * 1200;
  setTimeout(() => {
    launchRocket();
    if (Math.random() < 0.4) setTimeout(launchRocket, 180); // double launch
    scheduleNext();
  }, delay);
}
scheduleNext();

// ── RENDER LOOP ──
function loop() {
  requestAnimationFrame(loop);

  // fade trail
  ctx.fillStyle = 'rgba(0,0,0,0.18)';
  ctx.fillRect(0, 0, W, H);

  // rockets
  rockets = rockets.filter(r => {
    r.update();
    if (!r.exploded) r.draw();
    return !r.done;
  });

  // particles
  particles = particles.filter(p => {
    p.update(); p.draw();
    return !p.dead;
  });
}
loop();
</script>
</body>
</html>
